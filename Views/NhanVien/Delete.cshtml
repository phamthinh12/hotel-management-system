@model WebKhachSan.Models.NhanVien

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Xóa Nhân Viên";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="h3 mb-0" style="color: #dc3545; font-weight: 800; font-family: 'Manrope';">
                        ⚠️ Xóa Nhân Viên
                    </h1>
                    <p class="text-muted small mt-2">Xóa thông tin nhân viên: @Model.TenNhanVien</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>

            <div class="card shadow-sm border-0 border-danger">
                <div class="card-body p-4">
                    <div class="alert alert-warning alert-dismissible fade show" role="alert">
                        <strong>⚠️ Cảnh báo:</strong> Hành động này không thể hoàn tác! Tất cả thông tin liên quan đến nhân viên này sẽ bị xóa vĩnh viễn.
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-12 col-md-6">
                            <label class="form-label" style="font-weight: 600; color: #00236f;">Mã Nhân Viên</label>
                            <div class="form-control bg-light" style="border-color: #dee2e6;">@Model.MaNhanVien</div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label" style="font-weight: 600; color: #00236f;">Tên Nhân Viên</label>
                            <div class="form-control bg-light" style="border-color: #dee2e6;">@Model.TenNhanVien</div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label" style="font-weight: 600; color: #00236f;">Chức Vụ</label>
                            <div class="form-control bg-light" style="border-color: #dee2e6;">@Model.ChucVu</div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label" style="font-weight: 600; color: #00236f;">Điện Thoại</label>
                            <div class="form-control bg-light" style="border-color: #dee2e6;">@Model.DienThoai</div>
                        </div>

                        @if (Model.DiaChi != null)
                        {
                            <div class="col-12">
                                <label class="form-label" style="font-weight: 600; color: #00236f;">Địa Chỉ</label>
                                <div class="form-control bg-light" style="border-color: #dee2e6; min-height: 80px; overflow-y: auto;">@Model.DiaChi</div>
                            </div>
                        }
                    </div>

                    @if (Model.HoaDons != null && Model.HoaDons.Any())
                    {
                        <div class="alert alert-info">
                            <strong>ℹ️ Thông tin:</strong> Nhân viên này có <strong>@Model.HoaDons.Count()</strong> hóa đơn liên quan. 
                            Bạn cần xóa các hóa đơn này trước khi có thể xóa nhân viên.
                        </div>
                    }

                    <div class="d-flex gap-2 pt-3">
                        <a asp-action="Index" class="btn btn-lg btn-outline-secondary flex-grow-1">
                            <i class="bi bi-x-circle"></i> Hủy
                        </a>
                        @if (Model.HoaDons == null || !Model.HoaDons.Any())
                        {
                            <form asp-action="DeleteConfirmed" asp-route-id="@Model.MaNhanVien" method="post" style="flex-grow: 1;">
                                <button type="submit" class="btn btn-lg btn-danger w-100" onclick="return confirm('Bạn chắc chắn muốn xóa nhân viên này?');">
                                    <i class="bi bi-trash"></i> Xóa Nhân Viên
                                </button>
                            </form>
                        }
                        else
                        {
                            <button type="button" class="btn btn-lg btn-danger w-50 flex-grow-1" disabled>
                                <i class="bi bi-trash"></i> Không Thể Xóa
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .border-danger {
        border: 1px solid #dc3545 !important;
    }
</style>
