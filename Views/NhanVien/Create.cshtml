@model WebKhachSan.Models.NhanVien

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Thêm Nhân Viên Mới";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="h3 mb-0" style="color: var(--primary); font-weight: 800; font-family: 'Manrope';">
                        ➕ Thêm Nhân Viên Mới
                    </h1>
                    <p class="text-muted small mt-2">Nhập thông tin chi tiết của nhân viên mới</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post" class="needs-validation" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-dismissible fade show" role="alert" style="display: none;">
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            <strong>Lỗi!</strong> Vui lòng kiểm tra lại thông tin
                        </div>

                        <div class="row g-3">
                            <!-- Mã Nhân Viên -->
                            <div class="col-12 col-md-6">
                                <label for="MaNhanVien" class="form-label" style="font-weight: 600; color: #00236f;">
                                    Mã Nhân Viên <span style="color: #dc3545;">*</span>
                                </label>
                                <input type="text" class="form-control form-control-lg" id="MaNhanVien" 
                                       asp-for="MaNhanVien" placeholder="VD: NV001" required>
                                <span asp-validation-for="MaNhanVien" class="invalid-feedback"></span>
                            </div>

                            <!-- Tên Nhân Viên -->
                            <div class="col-12 col-md-6">
                                <label for="TenNhanVien" class="form-label" style="font-weight: 600; color: #00236f;">
                                    Tên Nhân Viên <span style="color: #dc3545;">*</span>
                                </label>
                                <input type="text" class="form-control form-control-lg" id="TenNhanVien" 
                                       asp-for="TenNhanVien" placeholder="Nhập tên nhân viên" required>
                                <span asp-validation-for="TenNhanVien" class="invalid-feedback"></span>
                            </div>

                            <!-- Chức Vụ -->
                            <div class="col-12 col-md-6">
                                <label for="ChucVu" class="form-label" style="font-weight: 600; color: #00236f;">
                                    Chức Vụ <span style="color: #dc3545;">*</span>
                                </label>
                                <select class="form-select form-select-lg" id="ChucVu" asp-for="ChucVu" required>
                                    <option value="">-- Chọn chức vụ --</option>
                                    <option value="Quản lý">Quản lý</option>
                                    <option value="Lễ tân">Lễ tân</option>
                                    <option value="Dọn phòng">Dọn phòng</option>
                                    <option value="Bảo vệ">Bảo vệ</option>
                                    <option value="Kỹ thuật">Kỹ thuật</option>
                                    <option value="Nhân viên">Nhân viên</option>
                                </select>
                                <span asp-validation-for="ChucVu" class="invalid-feedback"></span>
                            </div>

                            <!-- Ngày Sinh -->
                            <div class="col-12 col-md-6">
                                <label for="NgaySinh" class="form-label" style="font-weight: 600; color: #00236f;">
                                    Ngày Sinh
                                </label>
                                <input type="date" class="form-control form-control-lg" id="NgaySinh" 
                                       asp-for="NgaySinh">
                            </div>

                            <!-- Điện Thoại -->
                            <div class="col-12 col-md-6">
                                <label for="DienThoai" class="form-label" style="font-weight: 600; color: #00236f;">
                                    Điện Thoại <span style="color: #dc3545;">*</span>
                                </label>
                                <input type="tel" class="form-control form-control-lg" id="DienThoai" 
                                       asp-for="DienThoai" placeholder="0901234567" required>
                                <span asp-validation-for="DienThoai" class="invalid-feedback"></span>
                            </div>

                            <!-- Địa Chỉ -->
                            <div class="col-12">
                                <label for="DiaChi" class="form-label" style="font-weight: 600; color: #00236f;">
                                    Địa Chỉ
                                </label>
                                <textarea class="form-control form-control-lg" id="DiaChi" 
                                          asp-for="DiaChi" rows="3" placeholder="Nhập địa chỉ"></textarea>
                                <span asp-validation-for="DiaChi" class="invalid-feedback"></span>
                            </div>

                            <!-- Buttons -->
                            <div class="col-12 pt-3">
                                <button type="submit" class="btn btn-lg" 
                                        style="background: linear-gradient(135deg, #00236f, #1e3a8a); color: white; font-weight: 600; width: 100%;">
                                    <i class="bi bi-check-circle"></i> Thêm Nhân Viên
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    .form-control-lg, .form-select-lg {
        padding: 0.75rem 1rem;
        font-size: 1rem;
    }
    .form-control:focus, .form-select:focus {
        border-color: #00236f;
        box-shadow: 0 0 0 0.2rem rgba(0, 35, 111, 0.25);
    }
</style>
