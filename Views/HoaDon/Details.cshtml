@model WebKhachSan.Models.HoaDon

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Chi Tiết Hóa Đơn";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="h3 mb-0" style="color: var(--primary); font-weight: 800; font-family: 'Manrope';">
                        💳 Chi Tiết Hóa Đơn
                    </h1>
                    <p class="text-muted small mt-2">Thông tin chi tiết: @Model.MaHoaDon</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header" style="background: linear-gradient(135deg, #f8f9ff, #e6eeff); border-bottom: 2px solid #e6eeff;">
                    <h5 style="color: #00236f; font-weight: 700; margin: 0;">Thông Tin Hóa Đơn</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-12 col-md-6">
                            <label style="font-weight: 600; color: #6c757d; font-size: 0.85rem; text-transform: uppercase;">Mã Hóa Đơn</label>
                            <div style="font-size: 1.25rem; font-weight: 700; color: #00236f;">@Model.MaHoaDon</div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label style="font-weight: 600; color: #6c757d; font-size: 0.85rem; text-transform: uppercase;">Ngày Lập</label>
                            <div style="font-size: 1.125rem; color: #0d1c2e;">
                                @(Model.NgayLap?.ToString("dd/MM/yyyy HH:mm") ?? "---")
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label style="font-weight: 600; color: #6c757d; font-size: 0.85rem; text-transform: uppercase;">Khách Hàng</label>
                            <div style="font-size: 1rem; color: #0d1c2e;">
                                <strong>@Model.MaThuePhongNavigation?.MaKhachHangNavigation?.TenKhachHang</strong>
                                <div style="font-size: 0.875rem; color: #6c757d; margin-top: 0.25rem;">
                                    @Model.MaThuePhongNavigation?.MaKhachHangNavigation?.DienThoai
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label style="font-weight: 600; color: #6c757d; font-size: 0.85rem; text-transform: uppercase;">Nhân Viên Lập</label>
                            <div style="font-size: 1rem; color: #0d1c2e;">@Model.MaNhanVienNavigation?.TenNhanVien</div>
                        </div>

                        <div class="col-12">
                            <label style="font-weight: 600; color: #6c757d; font-size: 0.85rem; text-transform: uppercase;">Mã Thuê Phòng</label>
                            <div style="font-size: 1rem; color: #0d1c2e;">
                                <strong>@Model.MaThuePhong</strong>
                                <div style="font-size: 0.875rem; color: #6c757d; margin-top: 0.25rem;">
                                    Từ @(Model.MaThuePhongNavigation?.NgayNhan?.ToString("dd/MM/yyyy")) 
                                    đến @(Model.MaThuePhongNavigation?.NgayTra?.ToString("dd/MM/yyyy"))
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div style="background: linear-gradient(135deg, rgba(0, 35, 111, 0.05), rgba(30, 58, 138, 0.05)); padding: 1.5rem; border-radius: 0.75rem; border-left: 4px solid #00236f;">
                                <label style="font-weight: 600; color: #6c757d; font-size: 0.85rem; text-transform: uppercase;">Tổng Tiền</label>
                                <div style="font-size: 2rem; font-weight: 700; color: #00236f;">
                                    @((Model.TongTien?.ToString("N0") ?? "0") + " VND")
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.CthoaDons != null && Model.CthoaDons.Any())
            {
                <div class="card shadow-sm border-0">
                    <div class="card-header" style="background: linear-gradient(135deg, #f8f9ff, #e6eeff); border-bottom: 2px solid #e6eeff;">
                        <h5 style="color: #00236f; font-weight: 700; margin: 0;">
                            📋 Chi Tiết Hóa Đơn (@Model.CthoaDons.Count())
                        </h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead style="background: #f8f9ff;">
                                    <tr>
                                        <th style="color: #00236f; font-weight: 700;">Nội Dung</th>
                                        <th style="color: #00236f; font-weight: 700; text-align: right;">Số Tiền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var chi in Model.CthoaDons)
                                    {
                                        <tr>
                                            <td>@chi.NoiDung</td>
                                            <td style="text-align: right; color: #00236f; font-weight: 700;">
                                                @((chi.SoTien?.ToString("N0") ?? "0") + " VND")
                                            </td>
                                        </tr>
                                    }
                                    <tr style="border-top: 2px solid #e6eeff; font-weight: 700;">
                                        <td>TỔNG CỘNG</td>
                                        <td style="text-align: right; color: #00236f; font-size: 1.125rem;">
                                            @(Model.CthoaDons.Sum(ct => ct.SoTien ?? 0).ToString("N0") + " VND")
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }

            <div class="d-flex gap-2 mt-4">
                <a asp-action="Edit" asp-route-id="@Model.MaHoaDon" class="btn btn-lg btn-warning flex-grow-1">
                    <i class="bi bi-pencil"></i> Chỉnh Sửa
                </a>
                <a asp-action="Delete" asp-route-id="@Model.MaHoaDon" class="btn btn-lg btn-danger flex-grow-1">
                    <i class="bi bi-trash"></i> Xóa
                </a>
            </div>
        </div>
    </div>
</div>
