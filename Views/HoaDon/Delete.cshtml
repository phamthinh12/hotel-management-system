@model WebKhachSan.Models.HoaDon

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Xóa Hóa Đơn";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="h3 mb-0" style="color: #dc3545; font-weight: 800; font-family: 'Manrope';">
                        ⚠️ Xóa Hóa Đơn
                    </h1>
                    <p class="text-muted small mt-2">Xóa hóa đơn: @Model.MaHoaDon</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>

            <div class="card shadow-sm border-0 border-danger">
                <div class="card-body p-4">
                    <div class="alert alert-warning alert-dismissible fade show" role="alert">
                        <strong>⚠️ Cảnh báo:</strong> Hành động này không thể hoàn tác! Tất cả chi tiết hóa đơn sẽ bị xóa vĩnh viễn.
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-12 col-md-6">
                            <label class="form-label" style="font-weight: 600; color: #00236f;">Mã Hóa Đơn</label>
                            <div class="form-control bg-light" style="border-color: #dee2e6;">@Model.MaHoaDon</div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label" style="font-weight: 600; color: #00236f;">Khách Hàng</label>
                            <div class="form-control bg-light" style="border-color: #dee2e6;">
                                @Model.MaThuePhongNavigation?.MaKhachHangNavigation?.TenKhachHang
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label" style="font-weight: 600; color: #00236f;">Nhân Viên Lập</label>
                            <div class="form-control bg-light" style="border-color: #dee2e6;">@Model.MaNhanVienNavigation?.TenNhanVien</div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label" style="font-weight: 600; color: #00236f;">Ngày Lập</label>
                            <div class="form-control bg-light" style="border-color: #dee2e6;">
                                @(Model.NgayLap?.ToString("dd/MM/yyyy HH:mm") ?? "---")
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label" style="font-weight: 600; color: #00236f;">Tổng Tiền</label>
                            <div class="form-control bg-light" style="border-color: #dee2e6; font-size: 1.25rem; font-weight: 700; color: #dc3545;">
                                @((Model.TongTien?.ToString("N0") ?? "0") + " VND")
                            </div>
                        </div>
                    </div>

                    @if (Model.CthoaDons != null && Model.CthoaDons.Any())
                    {
                        <div class="alert alert-info">
                            <strong>ℹ️ Thông tin:</strong> Hóa đơn này có <strong>@Model.CthoaDons.Count()</strong> chi tiết.
                            Tất cả sẽ bị xóa theo.
                        </div>
                    }

                    <div class="d-flex gap-2 pt-3">
                        <a asp-action="Index" class="btn btn-lg btn-outline-secondary flex-grow-1">
                            <i class="bi bi-x-circle"></i> Hủy
                        </a>
                        <form asp-action="DeleteConfirmed" asp-route-id="@Model.MaHoaDon" method="post" style="flex-grow: 1;">
                            <button type="submit" class="btn btn-lg btn-danger w-100" onclick="return confirm('Bạn chắc chắn muốn xóa hóa đơn này?');">
                                <i class="bi bi-trash"></i> Xóa Hóa Đơn
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .border-danger {
        border: 1px solid #dc3545 !important;
    }
</style>
