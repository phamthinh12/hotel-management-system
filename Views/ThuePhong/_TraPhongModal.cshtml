@model TraPhongViewModel

<form id="traPhongForm" method="post" asp-controller="ThuePhong" asp-action="TraPhong" novalidate>
    @Html.AntiForgeryToken()
    <input asp-for="MaThuePhong" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="card border-0 bg-light mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="text-muted small text-uppercase">Mã phiếu thuê</div>
                    <div class="fw-bold fs-5">@Model.MaThuePhong</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small text-uppercase">Phòng</div>
                    <div class="fw-bold fs-5">@Model.SoPhong</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small text-uppercase">Khách hàng</div>
                    <div class="fw-semibold">@Model.TenKhachHang</div>
                </div>
            </div>
            <div class="row g-3 mt-2">
                <div class="col-md-6">
                    <div class="text-muted small text-uppercase">Ngày nhận phòng</div>
                    <div class="fw-semibold">@(Model.NgayNhan?.ToString("dd/MM/yyyy") ?? "-")</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small text-uppercase">Số ngày đã ở</div>
                    <div class="fw-semibold">
                        @{
                            var soNgay = Model.NgayNhan.HasValue
                                ? (DateTime.Today - Model.NgayNhan.Value.Date).Days
                                : 0;
                        }
                        @soNgay ngày
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12">
            <label asp-for="NgayTra" class="form-label fw-semibold">Ngày trả phòng</label>
            <input asp-for="NgayTra" type="date" class="form-control" />
            <span asp-validation-for="NgayTra" class="text-danger small"></span>
            <div class="form-text">Ngày trả phòng mặc định là hôm nay.</div>
        </div>
    </div>

    <div class="alert alert-warning mt-4 mb-0">
        <i class="bi bi-exclamation-triangle me-2"></i>
        Sau khi trả phòng, trạng thái phiếu thuê sẽ chuyển sang "Đã trả" và phòng sẽ được giải phóng.
    </div>
</form>
