@model IEnumerable<WebKhachSan.Models.GiaPhong>

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Quan ly Gia Phong";
}

<div class="container-fluid py-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Thanh cong!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Loi!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="mb-1 fw-bold">Gia Phong</h2>
            <p class="text-muted mb-0">Quan ly bang gia theo loai phong va xem cac phong dang ap dung.</p>
            @if (!string.IsNullOrEmpty(ViewBag.TenLoaiPhong))
            {
                <p class="text-info small mt-2 mb-0">Dang loc theo loai phong: <strong>@ViewBag.TenLoaiPhong</strong></p>
            }
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a asp-action="BulkSetPrice" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Them gia moi
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 fw-bold text-uppercase text-muted small">Ma Gia</th>
                        <th class="fw-bold text-uppercase text-muted small">Loai Phong</th>
                        <th class="text-end fw-bold text-uppercase text-muted small">Gia (VND)</th>
                        <th class="fw-bold text-uppercase text-muted small">Ngay Bat Dau</th>
                        <th class="fw-bold text-uppercase text-muted small">Ngay Ket Thuc</th>
                        <th class="text-center fw-bold text-uppercase text-muted small">Trang Thai</th>
                        <th class="text-center fw-bold text-uppercase text-muted small">Thao Tac</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            var isActive = item.NgayBatDau <= DateTime.Today &&
                                (item.NgayKetThuc == null || item.NgayKetThuc >= DateTime.Today);
                            var statusClass = isActive ? "bg-success" : "bg-secondary";
                            var statusText = isActive ? "Dang ap dung" : "Khong hieu luc";

                            <tr>
                                <td class="ps-4 fw-semibold text-primary">@item.MaGia</td>
                                <td>
                                    <div class="fw-semibold">@item.MaLoaiPhongNavigation?.TenLoaiPhong</div>
                                    <div class="text-muted small">@item.MaLoaiPhong</div>
                                </td>
                                <td class="text-end fw-bold">@item.Gia?.ToString("N0")</td>
                                <td>@item.NgayBatDau?.ToString("dd/MM/yyyy")</td>
                                <td>@(item.NgayKetThuc?.ToString("dd/MM/yyyy") ?? "Khong gioi han")</td>
                                <td class="text-center">
                                    <span class="badge @statusClass">@statusText</span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Details" asp-route-id="@item.MaGia" class="btn btn-outline-primary" title="Chi tiet">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.MaGia" class="btn btn-outline-warning" title="Chinh sua">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.MaGia" class="btn btn-outline-danger" title="Xoa">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                <p class="mt-3 mb-0">Chua co bang gia nao.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
